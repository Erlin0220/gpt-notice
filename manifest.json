{
  "manifest_version": 3,
  "name": "ChatGPT 任务完成提醒",
  "version": "0.3.0",
  "description": "在 ChatGPT 任务完成、等待操作或失败时发送 Windows 通知；通知显示问题标题、思考时长和回复第一行。",
  "minimum_chrome_version": "120",
  "permissions": [
    "notifications",
    "storage",
    "tabs",
    "windows"
  ],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "ChatGPT 任务提醒",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/chatgpt.png",
      "32": "icons/chatgpt.png",
      "48": "icons/chatgpt.png",
      "128": "icons/chatgpt.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/chatgpt.png",
    "32": "icons/chatgpt.png",
    "48": "icons/chatgpt.png",
    "128": "icons/chatgpt.png"
  }
}
